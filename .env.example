# Supabase — create a project at https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin dashboard — server-only; never use NEXT_PUBLIC_ prefix
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_EMAILS=you@example.com

# Facebook Login — same App Secret as Meta / Supabase Facebook provider
# Required for Meta data deletion callback (POST /api/facebook/data-deletion)
FACEBOOK_APP_SECRET=your-facebook-app-secret

# AI provider — swap models without code changes
AI_PROVIDER=google
AI_MODEL=gemini-2.0-flash
GOOGLE_GENERATIVE_AI_API_KEY=your-key-here

# Optional: switch provider to openai
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
